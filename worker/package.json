{
  "name": "velorouter-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:local": "wrangler r2 object put velorouter-graph/graph.bin --file ../testdata/ridge_world/graph.bin --local",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build:check": "wrangler deploy --dry-run --outdir dist"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^3.95.0"
  }
}
